{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://open-dictate.dev/contracts/overlay-lock.schema.json",
  "title": "Open Dictate private overlay lock",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "upstream", "compatibility"],
  "properties": {
    "schemaVersion": {"const": 1},
    "upstream": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version", "commit", "sourceArchiveSha256"],
      "properties": {
        "version": {"type": "string", "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+(?:-[0-9A-Za-z.-]+)?$"},
        "commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
        "sourceArchiveSha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      }
    },
    "compatibility": {
      "type": "object",
      "additionalProperties": false,
      "required": ["wireProtocolVersion", "productConfigSchema", "overlayTests"],
      "properties": {
        "wireProtocolVersion": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+$"},
        "productConfigSchema": {"type": "integer", "minimum": 1},
        "overlayTests": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}
      }
    }
  }
}
