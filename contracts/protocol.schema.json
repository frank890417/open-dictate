{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://open-dictate.dev/contracts/protocol.schema.json",
  "title": "Open Dictate daemon protocol manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "wireProtocolVersion", "transport", "commands", "errors"],
  "properties": {
    "schemaVersion": {"const": 1},
    "wireProtocolVersion": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+$"},
    "transport": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "framing", "socketMode"],
      "properties": {
        "kind": {"const": "unix-domain-socket"},
        "framing": {"const": "newline-delimited-json"},
        "socketMode": {"const": "0600"}
      }
    },
    "commands": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"enum": ["transcribe", "ping", "reload_lexicon", "add_pair", "stats"]}
    },
    "errors": {
      "type": "array",
      "uniqueItems": true,
      "items": {"enum": ["no_speech", "file_not_found", "asr_failed", "bad_request", "unknown_cmd", "add_pair_failed"]}
    }
  }
}
